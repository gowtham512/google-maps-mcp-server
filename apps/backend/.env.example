# Ollama Cloud
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=qwen3
OLLAMA_BASE_URL=https://api.ollama.com

# Google Maps Platform API key
MAPS_API_KEY=your_google_maps_api_key

# Database
# Use an unpooled Neon connection string with asyncpg, e.g.:
# postgresql+asyncpg://user:password@<endpoint-id>.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/dbname?sslmode=require

# Server
PORT=8000
