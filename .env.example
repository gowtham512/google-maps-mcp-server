# Ollama Cloud
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=qwen3
OLLAMA_BASE_URL=https://ollama.com

# Google Maps Platform API key
MAPS_API_KEY=your_google_maps_api_key

# Database (SQLite for now; replace with production URL later)
# In Docker, the db file is stored in /app/data via a persistent volume.
DATABASE_URL=sqlite+aiosqlite:///app/data/travel_agent.db

# Server
PORT=8000
