{
  "name": "google-maps-agent",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack agent with Google Maps tools, SQLite thread history, and cloud Ollama",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter db db:generate",
    "db:migrate": "pnpm --filter db db:migrate",
    "db:push": "pnpm --filter db db:push",
    "db:studio": "pnpm --filter db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
